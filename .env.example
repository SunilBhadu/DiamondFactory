# ─── App ───────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database ──────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diamondfactory
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/diamondfactory?schema=public"
MONGODB_URI=mongodb://mongo:mongo@localhost:27017/diamondfactory?authSource=admin
REDIS_URL=redis://localhost:6379

# ─── Elasticsearch ─────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ─── Auth ──────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ─── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─── Razorpay ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── AWS ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=diamondfactory-media
AWS_CLOUDFRONT_DOMAIN=cdn.diamondfactory.in

# ─── Email (AWS SES) ───────────────────────────────────
AWS_SES_FROM_EMAIL=noreply@diamondfactory.in
AWS_SES_FROM_NAME=Diamond Factory

# ─── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ─── Next.js Public ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
