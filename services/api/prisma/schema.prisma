generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CustomerRole {
  CUSTOMER
  ADMIN
  STAFF
  SUPPLIER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  QUALITY_CHECK
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentGateway {
  STRIPE
  RAZORPAY
  PAYPAL
}

enum ItemType {
  DIAMOND
  SETTING
  RING
  JEWELRY
  GIFT_CARD
}

enum DiamondShape {
  ROUND
  PRINCESS
  OVAL
  CUSHION
  MARQUISE
  PEAR
  RADIANT
  ASSCHER
  EMERALD
  HEART
}

enum CertificateLab {
  GIA
  IGI
  AGS
  HRD
  EGL
}

enum MetalType {
  PLATINUM
  WHITE_GOLD_18K
  YELLOW_GOLD_18K
  ROSE_GOLD_18K
  WHITE_GOLD_14K
  YELLOW_GOLD_14K
  ROSE_GOLD_14K
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum AppointmentType {
  IN_PERSON
  VIRTUAL
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  phone           String?
  passwordHash    String?
  firstName       String
  lastName        String
  avatar          String?
  role            CustomerRole @default(CUSTOMER)
  isEmailVerified Boolean      @default(false)
  phoneVerified   Boolean      @default(false)
  googleId        String?      @unique
  isActive        Boolean      @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  addresses           UserAddress[]
  sessions            UserSession[]
  orders              Order[]
  wishlists           Wishlist[]
  reviews             Review[]
  cartSnapshots       CartSnapshot[]
  processedRefunds    Refund[]
  userAppointments    AppointmentBooking[] @relation("UserAppointments")
  staffAppointments   AppointmentBooking[] @relation("StaffAppointments")

  @@index([email])
  @@index([googleId])
  @@map("users")
}

model UserAddress {
  id           String   @id @default(uuid())
  userId       String
  label        String?  // e.g. "Home", "Office"
  firstName    String
  lastName     String
  phone        String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String   @default("India")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[] @relation("ShippingAddress")

  @@index([userId])
  @@map("user_addresses")
}

model UserSession {
  id               String    @id @default(uuid())
  userId           String
  sessionToken     String    @unique
  refreshTokenHash String
  deviceInfo       Json?
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@map("user_sessions")
}

// ─── Supplier ─────────────────────────────────────────────────────────────────

model Supplier {
  id             String    @id @default(uuid())
  name           String
  code           String    @unique
  apiType        String?   // rapnet, idex, custom
  apiCredentials Json?
  markupPct      Float     @default(15)
  currency       String    @default("INR")
  leadTimeDays   Int       @default(7)
  isActive       Boolean   @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  diamonds Diamond[]

  @@map("suppliers")
}

// ─── Diamond ──────────────────────────────────────────────────────────────────

model Diamond {
  id              String         @id @default(uuid())
  sku             String         @unique
  stockId         String?        @unique
  supplierId      String?
  supplierStockId String?
  shape           DiamondShape
  caratWeight     Float
  color           String         // D-M
  clarity         String         // FL-I3
  cut             String?        // Ideal, Excellent, etc.
  polish          String?
  symmetry        String?
  fluorescence    String?        // None, Faint, etc.
  certificateLab  CertificateLab
  certificateNo   String?
  certificateUrl  String?
  depthPct        Float?
  tablePct        Float?
  lengthMm        Float?
  widthMm         Float?
  depthMm         Float?
  girdle          String?
  culet           String?
  crownAngle      Float?
  pavilionAngle   Float?
  lwRatio         Float?
  eyeClean        Boolean        @default(false)
  isLabGrown      Boolean        @default(false)
  originCountry   String?
  treatment       String?
  costPrice       Float?
  priceInr        Float
  markupPct       Float?
  currency        String         @default("INR")
  isAvailable     Boolean        @default(true)
  isReserved      Boolean        @default(false)
  isFeatured      Boolean        @default(false)
  isSold          Boolean        @default(false)
  isMemo          Boolean        @default(false)
  videoUrl        String?
  v360Url         String?
  inWishlistCount Int            @default(0)
  viewCount       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  images        DiamondImage[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  inventory     Inventory?

  @@index([shape])
  @@index([caratWeight])
  @@index([color])
  @@index([clarity])
  @@index([priceInr])
  @@index([isLabGrown])
  @@index([isAvailable])
  @@index([certificateLab])
  @@map("diamonds")
}

model DiamondImage {
  id        String   @id @default(uuid())
  diamondId String
  url       String
  type      String?  // photo, video_still
  angle     String?  // front, side, top
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  diamond Diamond @relation(fields: [diamondId], references: [id], onDelete: Cascade)

  @@index([diamondId])
  @@map("diamond_images")
}

// ─── Ring Setting ─────────────────────────────────────────────────────────────

model RingSetting {
  id                 String    @id @default(uuid())
  sku                String    @unique
  name               String
  slug               String    @unique
  style              String    // solitaire, halo, three-stone, vintage, pave, tension
  metalType          MetalType
  metalWeightG       Float?
  compatibleShapes   Json      @default("[]")  // DiamondShape[]
  minCarat           Float     @default(0.3)
  maxCarat           Float     @default(5.0)
  centerProng        Int?
  sideStones         Json?     // SideStone[]
  engravingAvailable Boolean   @default(true)
  maxEngravingChars  Int?      @default(20)
  basePrice          Float
  videoUrl           String?
  isActive           Boolean   @default(true)
  isAvailable        Boolean   @default(true)
  metaTitle          String?
  metaDescription    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  images        RingSettingImage[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]

  @@index([style])
  @@index([metalType])
  @@index([isActive])
  @@map("ring_settings")
}

model RingSettingImage {
  id        String   @id @default(uuid())
  settingId String
  url       String
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  setting RingSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@index([settingId])
  @@map("ring_setting_images")
}

// ─── Order ────────────────────────────────────────────────────────────────────

model Order {
  id                      String          @id @default(uuid())
  orderNumber             String          @unique
  userId                  String?
  guestEmail              String?
  status                  OrderStatus     @default(PENDING)
  paymentStatus           PaymentStatus   @default(PENDING)
  paymentGateway          PaymentGateway?
  currency                String          @default("INR")
  subtotal                Float
  discountAmount          Float           @default(0)
  gstAmount               Float           @default(0)
  taxAmount               Float           @default(0)
  shippingAmount          Float           @default(0)
  totalAmount             Float
  couponCode              String?
  shippingAddressId       String?
  shippingAddress         Json?           // JSON snapshot (used at order creation)
  shippingAddressSnapshot Json?
  billingAddressSnapshot  Json?
  notes                   String?
  giftMessage             String?
  isGift                  Boolean         @default(false)
  estimatedDelivery       DateTime?
  fulfilledAt             DateTime?
  cancelledAt             DateTime?
  cancelReason            String?
  metadata                Json?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  // Relations
  user            User?        @relation(fields: [userId], references: [id])
  shippingAddrRef UserAddress? @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  items           OrderItem[]
  payments        Payment[]
  refunds         Refund[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id             String    @id @default(uuid())
  orderId        String
  itemType       ItemType
  diamondId      String?
  ringSettingId  String?
  productId      String?   // MongoDB product ID
  sku            String?
  name           String?
  quantity       Int       @default(1)
  unitPrice      Float
  totalPrice     Float?
  metalType      String?
  ringSizeUs     Float?
  engravingText  String?
  engravingFont  String?
  customizations Json?
  snapshot       Json?     // Full product snapshot at time of purchase
  createdAt      DateTime  @default(now())

  // Relations
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  diamond     Diamond?     @relation(fields: [diamondId], references: [id])
  ringSetting RingSetting? @relation(fields: [ringSettingId], references: [id])
  reviews     Review[]

  @@index([orderId])
  @@index([diamondId])
  @@index([ringSettingId])
  @@map("order_items")
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id               String         @id @default(uuid())
  orderId          String
  gateway          PaymentGateway
  gatewayPaymentId String?
  gatewayIntentId  String?
  amount           Float
  currency         String         @default("INR")
  status           PaymentStatus  @default(PENDING)
  method           String?        // card, upi, netbanking, wallet
  methodDetails    Json?
  riskScore        Float?
  riskLevel        String?
  failureReason    String?
  gatewayResponse  Json?
  paidAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  order   Order    @relation(fields: [orderId], references: [id])
  refunds Refund[]

  @@index([orderId])
  @@index([gatewayPaymentId])
  @@index([status])
  @@map("payments")
}

model Refund {
  id              String   @id @default(uuid())
  paymentId       String
  orderId         String
  gatewayRefundId String?
  amount          Float
  reason          String?
  status          String   @default("PENDING") // PENDING, PROCESSING, SUCCEEDED, FAILED
  processedById   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  payment   Payment @relation(fields: [paymentId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id])
  processor User?   @relation(fields: [processedById], references: [id])

  @@index([paymentId])
  @@index([orderId])
  @@map("refunds")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model Inventory {
  id                String   @id @default(uuid())
  diamondId         String?  @unique
  itemType          String   // diamond, ring_setting, jewelry
  itemId            String   // references Diamond, RingSetting etc.
  sku               String   @unique
  quantity          Int      @default(0)
  reserved          Int      @default(0)
  reorderPoint      Int      @default(0)
  reorderQty        Int      @default(0)
  warehouseLocation String?
  updatedAt         DateTime @updatedAt

  diamond Diamond? @relation(fields: [diamondId], references: [id])

  @@index([itemType, itemId])
  @@map("inventory")
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id                 String   @id @default(uuid())
  userId             String
  orderItemId        String?
  productType        String   // diamond, ring_setting, jewelry
  productId          String
  rating             Int      // 1-5
  title              String?
  body               String?
  photos             Json     @default("[]")
  isVerifiedPurchase Boolean  @default(false)
  isPublished        Boolean  @default(false)
  helpfulCount       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user      User       @relation(fields: [userId], references: [id])
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])

  @@index([productType, productId])
  @@index([userId])
  @@map("reviews")
}

// ─── Wishlist ─────────────────────────────────────────────────────────────────

model Wishlist {
  id         String   @id @default(uuid())
  userId     String
  name       String   @default("My Wishlist")
  shareToken String   @unique @default(uuid())
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@index([userId])
  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(uuid())
  wishlistId String
  itemType   String   // diamond, setting, jewelry
  diamondId  String?
  settingId  String?
  productId  String?  // MongoDB product ID
  notes      String?
  createdAt  DateTime @default(now())

  wishlist  Wishlist     @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  diamond   Diamond?     @relation(fields: [diamondId], references: [id])
  setting   RingSetting? @relation(fields: [settingId], references: [id])

  @@unique([wishlistId, itemType, diamondId])
  @@unique([wishlistId, itemType, settingId])
  @@index([wishlistId])
  @@map("wishlist_items")
}

// ─── Cart Snapshot ────────────────────────────────────────────────────────────

model CartSnapshot {
  id                String   @id @default(uuid())
  userId            String?
  sessionId         String?
  cartData          Json
  totalAmount       Float
  recoveryEmailSent Boolean  @default(false)
  lastActivity      DateTime @default(now())
  createdAt         DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
  @@map("cart_snapshots")
}

// ─── Coupon ───────────────────────────────────────────────────────────────────

model Coupon {
  id                String       @id @default(uuid())
  code              String       @unique
  discountType      DiscountType
  discountValue     Float
  minOrderAmount    Float?
  maxDiscountAmount Float?
  usageLimit        Int?
  usageCount        Int          @default(0)
  expiresAt         DateTime?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([code])
  @@map("coupons")
}

// ─── Shipping Method ──────────────────────────────────────────────────────────

model ShippingMethod {
  id            String   @id @default(uuid())
  name          String
  carrier       String
  estimatedDays Int
  baseRate      Float
  freeAbove     Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("shipping_methods")
}

// ─── Appointment Booking ──────────────────────────────────────────────────────

model AppointmentBooking {
  id          String            @id @default(uuid())
  userId      String?
  type        AppointmentType
  date        DateTime
  time        String
  notes       String?
  status      AppointmentStatus @default(PENDING)
  staffId     String?
  meetingLink String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user  User? @relation("UserAppointments", fields: [userId], references: [id])
  staff User? @relation("StaffAppointments", fields: [staffId], references: [id])

  @@index([userId])
  @@index([date])
  @@map("appointment_bookings")
}
